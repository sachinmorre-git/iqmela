// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CANDIDATE
  INTERVIEWER
  ADMIN
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum PositionStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
  ARCHIVED
}

enum ResumeParsingStatus {
  UPLOADED
  QUEUED_FOR_AI
  EXTRACTING
  EXTRACTED
  RANKING
  RANKED
  FAILED
}

enum ExtractionStatus {
  PENDING
  EXTRACTING
  EXTRACTED
  FAILED
}

enum InviteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

enum BatchActionType {
  EXTRACTION
  RANKING
  ADVANCED_JUDGMENT
  INVITE_DRAFTS
  INVITE_SEND
  FULL_PIPELINE
  SHORTLIST_UPDATE
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  role               Role                @default(CANDIDATE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  
  // Relations
  candidateProfile   CandidateProfile?
  interviewerProfile InterviewerProfile?
  orgAdminProfile    OrgAdminProfile?

  // Interview References mapping explicitly to distinguishing relation names
  interviewsAsCandidate   Interview[] @relation("CandidateInterviews")
  interviewsAsInterviewer Interview[] @relation("InterviewerInterviews")

  // Positions created by this user (Org Admin)
  positionsCreated        Position[]  @relation("PositionCreator")
}

model CandidateProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  phone             String?
  timezone          String?
  skills            String?  
  resumeUrl         String?
  experienceSummary String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterviewerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  title             String?
  department        String?
  timezone          String?
  expertise         String?  
  bio               String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrgAdminProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  orgName      String?
  timezone     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Position {
  id             String         @id @default(cuid())
  title          String
  department     String?
  location       String?
  employmentType String?        // e.g. FULL_TIME, PART_TIME, CONTRACT, INTERNSHIP
  description    String?        // Short public-facing summary
  jdText         String?        // Full job description text (long-form)
  status         PositionStatus @default(DRAFT)

  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // AI JD Analysis — populated when AI parses the job description
  structuredJdJson        Json?   // Full structured breakdown of the JD produced by AI
  jdKeywordsJson          Json?   // Key terms and phrases extracted from the JD
  jdRequiredSkillsJson    Json?   // Must-have skills as parsed by AI
  jdPreferredSkillsJson   Json?   // Nice-to-have skills as parsed by AI

  // AI Pipeline Timestamps — updated after each bulk operation
  aiLastExtractionRunAt   DateTime?  // When the last bulk extraction was triggered
  aiLastRankingRunAt      DateTime?  // When the last bulk ranking was triggered
  aiLastPipelineRunAt     DateTime?  // When the last full pipeline run was triggered
  aiPipelineSummaryJson   Json?      // Summary of latest full pipeline run (counts, status, errors)

  createdBy      User           @relation("PositionCreator", fields: [createdById], references: [id], onDelete: Cascade)

  // Resumes uploaded against this position
  resumes        Resume[]
  invites        InterviewInvite[]
  batchRuns      PositionBatchRun[]
  aiUsageLogs    AiUsageLog[]
}

model Resume {
  id                String               @id @default(cuid())
  positionId        String
  originalFileName  String               // The filename as uploaded by the admin
  storagePath       String               // Path/key in the storage bucket (e.g. S3 key)
  mimeType          String               // e.g. "application/pdf"
  fileSize          Int                  // File size in bytes
  uploadedAt        DateTime             @default(now()) // When the file was received
  extractedText     String?              // Raw text extracted from the CV (legacy compat)
  rawExtractedText  String?              // Full raw text from PDF/DOCX parser before any AI processing
  
  // Extracted Candidate Info
  candidateName          String?
  candidateEmail         String?
  phoneNumber            String?
  linkedinUrl            String?
  parsingNotes           String?
  location               String?
  skillsJson             Json?
  experienceYears        Float?
  educationJson          Json?
  companiesJson          Json?
  extractionProvider     String?
  extractionConfidence   Float?
  validationWarningsJson Json?
  aiSummaryJson          Json?            // Overall AI-generated summary/profile of the candidate
  extractionStatus       ExtractionStatus? @default(PENDING) // Granular AI extraction lifecycle
  extractedAt            DateTime?         // Timestamp when AI extraction last completed successfully
  
  // AI Ranking Info
  matchScore             Int?             // Legacy: kept for backward compat
  matchLabel             String?          // Legacy: kept for backward compat
  jdMatchScore           Int?             // Explicit JD-based match score (0-100)
  jdMatchLabel           String?          // e.g. "Strong Match", "Partial Match", "Low Match"
  matchedSkillsJson      Json?
  missingSkillsJson      Json?
  rankingExplanation     String?
  notableStrengthsJson   Json?
  possibleGapsJson       Json?
  rankingStatus          String?              @default("UNRANKED")
  rankedAt               DateTime?
  aiRawOutputJson        Json?

  // Advanced AI Intelligence
  aiRecommendationLabel     String?   // "STRONG_HIRE", "HIRE", "MAYBE", "NO_HIRE"
  aiRecommendationRationale String?
  aiInterviewFocusJson      Json?     // Array of focus areas (topics, strengths to validate, gaps to probe)
  aiInterviewQuestionsJson  Json?     // Array of structured interview questions
  aiRedFlagsJson            Json?     // Array of structured inconsistencies/warnings
  
  advancedJudgmentJson      Json?
  advancedJudgmentProvider  String?
  advancedJudgmentAt        DateTime?
  finalRecommendationLabel  String?
  finalRecommendationReason String?
  recruiterReviewNeeded     Boolean   @default(false)

  isNearDuplicate           Boolean   @default(false)
  duplicateReason           String?

  parsingStatus          ResumeParsingStatus  @default(UPLOADED)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  // Recruiter Workflow
  isShortlisted          Boolean              @default(false)
  recruiterNotes         String?
  overrideName           String?
  overrideEmail          String?
  overridePhone          String?
  overrideLinkedinUrl    String?

  position               Position             @relation(fields: [positionId], references: [id], onDelete: Cascade)
  invite                 InterviewInvite?
  aiUsageLogs            AiUsageLog[]
}

model InterviewInvite {
  id             String       @id @default(cuid())
  resumeId       String       @unique
  positionId     String
  targetEmail    String
  status         InviteStatus @default(DRAFT)
  lastDeliveryStatus String?  // Stores Resend webhook events (e.g. delivered, bounced)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  resume         Resume       @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  position       Position     @relation(fields: [positionId], references: [id], onDelete: Cascade)
}

model Interview {
  id               String          @id @default(cuid())
  title            String
  scheduledAt      DateTime
  durationMinutes  Int             @default(60)
  status           InterviewStatus @default(SCHEDULED)
  roomName         String?         // Allows tracking LiveKit or external meeting IDs natively
  notes            String?         // Added for the scheduler form
  
  candidateId      String
  interviewerId    String

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Two-way relational mappers handling dual user intersections
  candidate        User            @relation("CandidateInterviews", fields: [candidateId], references: [id])
  interviewer      User            @relation("InterviewerInterviews", fields: [interviewerId], references: [id])

  feedback         InterviewFeedback?
}

model InterviewFeedback {
  id              String   @id @default(cuid())
  interviewId     String   @unique
  interviewerId   String
  rating          Int
  recommendation  String   // "HIRE", "NO_HIRE", "STRONG_HIRE"
  notes           String?
  summary         String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model PositionBatchRun {
  id             String          @id @default(cuid())
  positionId     String
  actionType     BatchActionType
  status         String          // "COMPLETED", "PARTIAL_SUCCESS", "FAILED"
  totalProcessed Int
  succeeded      Int
  failed         Int
  skipped        Int
  detailsJson    Json?           // Error logs or specific details
  createdAt      DateTime        @default(now())

  position       Position        @relation(fields: [positionId], references: [id], onDelete: Cascade)
}

model AiUsageLog {
  id             String   @id @default(cuid())
  positionId     String?
  resumeId       String?
  provider       String
  model          String
  taskType       String   // e.g. EXTRACTION, RANKING, JD_ANALYSIS, ADVANCED_JUDGMENT
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  totalTokens    Int      @default(0)
  estimatedCost  Float    @default(0)
  promptVersion  String?
  createdAt      DateTime @default(now())

  position       Position? @relation(fields: [positionId], references: [id], onDelete: Cascade)
  resume         Resume?   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}
